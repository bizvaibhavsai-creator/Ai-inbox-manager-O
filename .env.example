# ===========================================
#  AI Inbox Manager — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# ---- Your VPS IP (CHANGE THIS) ----
# Replace with your Hostinger VPS IP address
VPS_IP=YOUR_VPS_IP_HERE

# ---- Instantly.ai API ----
INSTANTLY_API_KEY=
INSTANTLY_WEBHOOK_SECRET=

# ---- OpenAI ----
OPENAI_API_KEY=

# ---- n8n credentials ----
N8N_USER=admin
N8N_PASSWORD=change_this_password

# ---- n8n internal (don't change) ----
N8N_SLACK_WEBHOOK_URL=http://n8n:5678/webhook/slack-notify
N8N_BASE_URL=http://n8n:5678

# ---- Webhook URL (for n8n to receive Slack interactions) ----
# Set this to http://YOUR_VPS_IP:5678
WEBHOOK_URL=http://YOUR_VPS_IP_HERE:5678

# ---- Backend public URL (for dashboard to call API) ----
# Set this to http://YOUR_VPS_IP:8888
BACKEND_PUBLIC_URL=http://YOUR_VPS_IP_HERE:8888

# ---- Google Sheets ----
GOOGLE_SHEET_ID=

# ---- CORS (allow dashboard to call backend) ----
CORS_ORIGINS=["http://YOUR_VPS_IP_HERE:8080"]
